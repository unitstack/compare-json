{
  "name": "@compare-json/core",
  "license": "MIT",
  "version": "0.1.1",
  "description": "Lightweight library for structured JSON comparison.",
  "keywords": [
    "compare json",
    "json comparison",
    "json diff"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unitstack/compare-json.git",
    "directory": "packages/compare-json-core"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "lint": "eslint",
    "test": "npm run test-type && npm run test-coverage",
    "test-type": "tsc --noEmit",
    "test-unit": "vitest run",
    "test-coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@compare-json/eslint-config": "workspace:*",
    "@compare-json/tsconfig": "workspace:*",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "@rslib/core": "^0.21.5",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
