{
  "name": "@compare-json/cli",
  "license": "MIT",
  "version": "0.1.1",
  "description": "Command-line tool and MCP server for structured JSON comparison.",
  "keywords": [
    "compare json",
    "json comparison",
    "json diff"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unitstack/compare-json.git",
    "directory": "packages/compare-json-cli"
  },
  "bin": {
    "compare-json": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc-alias",
    "lint": "eslint",
    "test": "npm run test-type && npm run test-coverage && npm run test-e2e",
    "test-type": "tsc --noEmit",
    "test-unit": "vitest run src",
    "test-coverage": "vitest run src --coverage",
    "test-e2e": "vitest run e2e",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@compare-json/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^14.0.3",
    "package-directory": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@compare-json/eslint-config": "workspace:*",
    "@compare-json/tsconfig": "workspace:*",
    "@types/commander": "^2.12.5",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
